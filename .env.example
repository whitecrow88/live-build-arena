# ================================================================
# Live Build Arena — Environment Variables
# Copy to .env.local and fill in your values
# ================================================================

# ── Supabase ─────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api

# Public URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Public anon key (safe to expose in browser — RLS controls access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Service role key (SECRET — server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# Optional: direct DB connection (used by supabase CLI migrations)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Kick (Streamer Platform) ──────────────────────────────────────
# Get from: https://kick.com/developer (early access — apply for API access)
# Webhook secret: set when creating a webhook subscription in Kick developer portal

# HMAC secret used to verify incoming Kick webhook payloads
KICK_WEBHOOK_SECRET=your_kick_webhook_secret_here

# OAuth client credentials (for future: fetching channel data, etc.)
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret

# ── GitHub ────────────────────────────────────────────────────────
# Create a fine-grained Personal Access Token at:
# https://github.com/settings/tokens?type=beta
# Required permissions: Contents (read & write), Metadata (read)

GITHUB_TOKEN=your_github_fine_grained_pat_here
# The GitHub org or username to create repos under
GITHUB_ORG=your-github-username-or-org

# ── Vercel ────────────────────────────────────────────────────────
# Create a token at: https://vercel.com/account/tokens

VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: your Vercel team ID (leave blank if personal account)
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxx

# ── AI Builder ───────────────────────────────────────────────────
# OpenAI API key — used as FALLBACK if Codex CLI is not available
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Path to the Codex CLI binary (preferred for cost efficiency)
# Install: npm install -g @openai/codex
# Then: which codex  →  /usr/local/bin/codex
CODEX_CLI_PATH=/usr/local/bin/codex

# Set to "true" to use template scaffolding instead of real AI (dev/testing)
USE_MOCK_BUILDER=true

# ── App Config ───────────────────────────────────────────────────
# Your deployment URL (used for internal API calls and overlay links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin secret — used to protect /admin/* routes in MVP
# Generate a strong random string: openssl rand -hex 32
ADMIN_SECRET=your_super_secret_admin_password_here

# Webhook signing secret (optional extra layer for webhook validation)
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here

# ── Twitch (Future) ───────────────────────────────────────────────
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_WEBHOOK_SECRET=

# ── Stripe (Future — Post-MVP) ────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
